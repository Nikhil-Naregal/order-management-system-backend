<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="0001-add-order-lines-created-at" author="assistant">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="order_lines" columnName="created_at"/>
            </not>
        </preConditions>

        <addColumn tableName="order_lines">
            <column name="created_at" type="timestamp with time zone" defaultValueComputed="NOW()"/>
        </addColumn>

        <update tableName="order_lines">
            <column name="created_at" valueComputed="NOW()"/>
        </update>

        <addNotNullConstraint tableName="order_lines" columnName="created_at" columnDataType="timestamp with time zone"/>
    </changeSet>

</databaseChangeLog>
